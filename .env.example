# ── Security ────────────────────────────────────────────────────────────────
# Admin panel key — CHANGE THIS before exposing to a network
ADMIN_SECRET=changeme

# ── Claude API (admin world generator) ──────────────────────────────────────
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (Game Master LLM) ─────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3

# ── Debug logging ────────────────────────────────────────────────────────────
# Set to 1 to write per-player debug logs to logs/<world_id>/<player>_<ts>.log
# Logs: inputs, script triggers, LLM send/receive with timings, state snapshots
DEBUG_PLAYERS=0

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
